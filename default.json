{
  "$schema": "https://docs.renovatebot.com/renovate-schema.json",
  "description": "Shared Renovate preset for the Asteby + Metacore ecosystem. Singularity model: every update auto-merges, regardless of severity, manager or package. The platform team publishes, every consumer app inherits — automatically, in cascade. Updates are scheduled off-peak (nights + weekends, America/Mexico_City) with low PR limits so the single shared self-hosted CI runner is never flooded and human deploys win the queue during work hours.",
  "extends": [
    "config:recommended",
    ":semanticCommits",
    ":dependencyDashboard"
  ],
  "timezone": "America/Mexico_City",
  "schedule": ["after 10pm and before 6am every weekday", "every weekend"],
  "prHourlyLimit": 2,
  "prConcurrentLimit": 3,
  "labels": ["dependencies"],
  "rebaseWhen": "behind-base-branch",
  "constraints": {
    "pnpm": "10.28.2"
  },
  "automergeType": "pr",
  "automergeStrategy": "squash",
  "platformAutomerge": false,
  "packageRules": [
    {
      "description": "Universal singularity — auto-merge EVERY update type for EVERY package across npm, gomod, dockerfile, github-actions and lockfiles.",
      "matchManagers": ["npm", "gomod", "dockerfile", "docker-compose", "github-actions", "regex"],
      "matchUpdateTypes": ["patch", "minor", "major", "pin", "digest", "lockFileMaintenance", "rollback", "bump", "replacement"],
      "automerge": true,
      "platformAutomerge": false
    },
    {
      "description": "Metacore platform (npm) grouped into one cascade PR.",
      "matchManagers": ["npm"],
      "matchPackagePatterns": ["^@asteby/metacore-"],
      "groupName": "metacore platform",
      "groupSlug": "metacore-platform"
    },
    {
      "description": "Metacore kernel (Go) grouped.",
      "matchManagers": ["gomod"],
      "matchPackagePatterns": ["^github.com/asteby/metacore-"],
      "groupName": "metacore platform",
      "groupSlug": "metacore-platform"
    },
    {
      "description": "React + TanStack + Radix grouped to land together (avoid peerDep clashes).",
      "matchPackagePatterns": ["^react", "^@tanstack/", "^@radix-ui/"],
      "groupName": "react ecosystem"
    },
    {
      "description": "Fiber + GORM grouped (Go web/data stack).",
      "matchPackagePatterns": ["^github.com/gofiber/", "^gorm.io/"],
      "groupName": "fiber + gorm"
    }
  ],
  "lockFileMaintenance": {
    "enabled": true,
    "automerge": true,
    "schedule": ["before 6am on monday"]
  },
  "vulnerabilityAlerts": {
    "labels": ["security"],
    "automerge": true
  }
}
