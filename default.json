{
  "$schema": "https://docs.renovatebot.com/renovate-schema.json",
  "description": "Shared Renovate preset for the Asteby + Metacore ecosystem. Singularity model: the platform team publishes, every consumer app inherits — automatically, in cascade.",
  "extends": [
    "config:recommended",
    ":semanticCommits",
    ":dependencyDashboard"
  ],
  "schedule": ["at any time"],
  "prHourlyLimit": 0,
  "prConcurrentLimit": 0,
  "labels": ["dependencies"],
  "rebaseWhen": "behind-base-branch",
  "automergeType": "pr",
  "automergeStrategy": "squash",
  "platformAutomerge": true,
  "packageRules": [
    {
      "description": "Metacore platform (npm) — auto-merge ALL update types so consumer apps stay in lockstep with the kernel/SDK release train.",
      "matchManagers": ["npm"],
      "matchPackagePatterns": ["^@asteby/metacore-"],
      "groupName": "metacore platform",
      "groupSlug": "metacore-platform",
      "matchUpdateTypes": ["patch", "minor", "major"],
      "automerge": true,
      "platformAutomerge": true
    },
    {
      "description": "Metacore kernel (Go) — auto-merge ALL update types.",
      "matchManagers": ["gomod"],
      "matchPackagePatterns": ["^github.com/asteby/metacore-"],
      "groupName": "metacore platform",
      "groupSlug": "metacore-platform",
      "matchUpdateTypes": ["patch", "minor", "major"],
      "automerge": true,
      "platformAutomerge": true
    },
    {
      "description": "Generic ecosystem updates — auto-merge minor and patch.",
      "matchManagers": ["npm", "gomod"],
      "matchUpdateTypes": ["patch", "minor"],
      "automerge": true,
      "platformAutomerge": true
    },
    {
      "description": "React + TanStack + Radix grouped to land together (avoid peerDep clashes).",
      "matchPackagePatterns": ["^react", "^@tanstack/", "^@radix-ui/"],
      "groupName": "react ecosystem",
      "automerge": true,
      "platformAutomerge": true
    },
    {
      "description": "Fiber + GORM grouped (Go web/data stack).",
      "matchPackagePatterns": ["^github.com/gofiber/", "^gorm.io/"],
      "groupName": "fiber + gorm",
      "automerge": true,
      "platformAutomerge": true
    }
  ],
  "vulnerabilityAlerts": {
    "labels": ["security"],
    "automerge": true,
    "platformAutomerge": true
  }
}
